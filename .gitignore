# ============================================
dist/
build/
out/
release/
*.exe
*.out
*.app
*.dll
*.so
*.dylib
*.jar
*.war
*.ear

# ============================================
# 9. ARCHIVOS DE DOCUMENTACIÓN GENERADA
# ============================================
docs/_build/
docs/api/
docs/*.tmp
docs/*.bak

reports/
test-reports/
*.html
*.xml
*.json

# ============================================
# 10. ARCHIVOS ESPECÍFICOS DE SIGAL-LF
# ============================================
incremento-*/resultados-pruebas/
incremento-*/reporte-*.html
incremento-*/jmeter-*.csv
incremento-*/pruebas-*.log

*.pdf
*.xlsx
*.xls
*.csv
*.zip
*.rar

backup-*.sql
dump-*.sql
*.backup

# ============================================
