# ============================================
# .gitignore para SIGAL-LF
# Proyecto: Sistema Integrado de Gestión de Almacén e Inventario
# Tienda "La Fábrica" - Sucursal Huancayo
# Stack: Node.js + Express + PostgreSQL + Vanilla JS
# ============================================

# ============================================
# 1. DEPENDENCIAS DE NODE.JS
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# 2. VARIABLES DE ENTORNO Y CONFIGURACIÓN SENSIBLE
# ============================================
.env
.env.local
.env.development
.env.production
.env.test
.env.example
.env.*.local

supabase/config.toml
supabase/.env
render.yaml
render.yml

# ============================================
# 3. ARCHIVOS DE LOGS Y TEMPORALES
# ============================================
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~
*.bak
*.backup
*.orig

# ============================================
# 4. ARCHIVOS DEL SISTEMA OPERATIVO
# ============================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
*.pid
*.socket

# ============================================
# 5. ARCHIVOS DE BASES DE DATOS LOCALES
# ============================================
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-shm
*.db-wal
*.sqlite-journal

# ============================================
# 6. ARCHIVOS DE PRUEBAS Y COBERTURA
# ============================================
coverage/
.nyc_output/
*.lcov
*.cov
jest.config.js
jest.setup.js
*.test.js
*.spec.js
__tests__/
__mocks__/

# ============================================
# 7. ARCHIVOS DE EDITOR E IDE
# ============================================
# Visual Studio Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.code-workspace

# IntelliJ / WebStorm / PhpStorm
.idea/
*.iml
.project
.classpath
.settings/
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace
*.sublime-settings

# Vim
.vim/
.vimrc
*.swp
*.swo

# Emacs
.emacs.d/
*.elc

# ============================================
