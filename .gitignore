.nvmrc
.node-version
.npmrc
.yarnrc
.yarnrc.yml

*.dockerignore
Dockerfile.*
docker-compose.*.yml

*.tfstate
*.tfstate.*
.terraform/

# ============================================
# 17. ARCHIVOS TEMPORALES DE USUARIO
