# ============================================
# .gitignore para SIGAL-LF - Incremento 2
# Proyecto: Sistema Integrado de Gestión de Almacén e Inventario
# Tienda "La Fábrica" - Sucursal Huancayo
# Stack: Node.js + Express + PostgreSQL + Vanilla JS
# ============================================

# ============================================
# 1. DEPENDENCIAS DE NODE.JS
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# 2. VARIABLES DE ENTORNO Y CONFIGURACIÓN SENSIBLE
# ============================================
# Variables de entorno
.env
.env.local
.env.development
.env.production
.env.test
.env.example

# Configuración de Supabase
supabase/config.toml
supabase/.env

# Configuración de Render
render.yaml

# ============================================
# 3. ARCHIVOS DE LOGS Y TEMPORALES
# ============================================
# Logs
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Archivos temporales
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~

# ============================================
# 4. ARCHIVOS DEL SISTEMA OPERATIVO
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================
# 5. ARCHIVOS DE BASES DE DATOS LOCALES
# ============================================
# Bases de datos locales (si se usan para pruebas)
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-shm
*.db-wal

# ============================================
# 6. ARCHIVOS DE PRUEBAS Y COBERTURA
# ============================================
coverage/
.nyc_output/
*.lcov
*.cov
jest.config.js
*.test.js
*.spec.js
__tests__/
__mocks__/

# ============================================
# 7. ARCHIVOS DE EDITOR E IDE
# ============================================
.vscode/
.idea/
*.iml
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.vim/
.vimrc
.emacs.d/

# ============================================
# 8. ARCHIVOS DE DESPLIEGUE Y COMPILACIÓN
# ============================================
dist/
build/
out/
*.exe
*.out
*.app
*.dll
*.so
*.dylib

# ============================================
# 9. ARCHIVOS ESPECÍFICOS DE SIGAL-LF
# ============================================
# Reportes de pruebas
incremento-*/resultados-pruebas/
incremento-*/reporte-*.html
incremento-*/jmeter-*.csv

# Archivos de reportes generados
*.pdf
*.xlsx
*.xls
*.zip

# Archivos de documentación generada temporalmente
docs/*.tmp
docs/*.bak

# ============================================
# 10. OTROS ARCHIVOS COMUNES
# ============================================
# Claves y certificados
*.pem
*.key
*.crt
*.csr
*.cer
*.p12
*.pfx

# Secretos y archivos de configuración sensible
*.secrets
*.secret

# Archivos de respaldo
*.bak
*.backup
*.orig

# ============================================
# FIN DEL ARCHIVO .gitignore
# Proyecto SIGAL-LF · UPLA · MDS 2026-1
# ============================================
