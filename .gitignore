# ============================================
*.pem
*.key
*.crt
*.csr
*.cer
*.p12
*.pfx
*.p8
*.pub

# ============================================
# 12. SECRETOS Y ARCHIVOS DE CONFIGURACIÓN SENSIBLE
# ============================================
*.secrets
*.secret
*.token
*.credentials
*.auth

# ============================================
# 13. ARCHIVOS DE DEPENDENCIAS Y CACHÉ
# ============================================
.npm/
.npm-cache/
.yarn/
.yarn-cache/
.pnpm-store/

# ============================================
# 14. ARCHIVOS DE GIT
# ============================================
.git/
.gitignore
.gitattributes
.gitmodules

# ============================================
# 15. ARCHIVOS DE GITHUB ACTIONS
# ============================================
.github/.env
.github/*.secret

# ============================================
# 16. OTROS ARCHIVOS COMUNES
