# ============================================
# SIGAL-LF - Variables de Entorno (Ejemplo)
# Copia este archivo como .env y completa los valores
# ============================================

# Base de Datos (Supabase)
DATABASE_URL="postgresql://usuario:password@host:5432/sigal_db"

# JWT para Autenticación
JWT_SECRET="clave-secreta-para-jwt"

# Puerto del Servidor
PORT=3000

# Entorno de Ejecución
NODE_ENV=development

# URL del Frontend (para CORS)
FRONTEND_URL="http://localhost:3000"

# Configuración de Render (Despliegue)
RENDER_API_KEY="tu-api-key-de-render"
